# .htaccess for Your Energy Best
# Security, Performance, and Clean URLs

# Enable rewrite engine
RewriteEngine On

# Force HTTPS (redirect HTTP to HTTPS)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www (redirect www to non-www)
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Clean URL for build page: /build works without /index.html
RewriteRule ^build/?$ build/index.html [L]

# Prevent directory browsing
Options -Indexes

# ========================================
# SECURITY: Protect Sensitive Files
# ========================================

# Block access to sensitive files
<FilesMatch "\.(log|bak|backup|sql|md|gitignore|ini|sh)$">
    Require all denied
</FilesMatch>

# Protect backup directory
<DirectoryMatch "backups">
    Require all denied
</DirectoryMatch>

# Protect .git folder (if accidentally deployed)
<DirectoryMatch "\.git">
    Require all denied
</DirectoryMatch>

# Allow content.json to be read by JavaScript but set no-cache
<Files "content.json">
    Require all granted
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</Files>

# ========================================
# CACHING: Performance Optimization
# ========================================

# Don't cache HTML files (always get fresh version)
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Don't cache PHP files
<FilesMatch "\.(php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Cache images for 7 days
<FilesMatch "\.(jpg|jpeg|png|gif|webp|ico|svg)$">
    Header set Cache-Control "max-age=604800, public"
</FilesMatch>

# Cache CSS and JS for 1 day (so updates show quickly)
<FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=86400, public"
</FilesMatch>

# ========================================
# COMPRESSION: Reduce File Sizes
# ========================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ========================================
# SECURITY HEADERS
# ========================================

<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Enable XSS protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove X-Powered-By header (security through obscurity)
    Header unset X-Powered-By
</IfModule>

# ========================================
# PHP SETTINGS (for uploads & processing)
# ========================================

<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# ========================================
# CUSTOM ERROR PAGES (optional)
# ========================================

# Uncomment these if you create custom error pages
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html

# End of .htaccess
